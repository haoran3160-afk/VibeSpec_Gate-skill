# Default generated scan output
outputs/

# Curated LLM quality fixtures are source-controlled regression inputs even
# though their leaf directory is named outputs.
!tests/evaluation_cases/llm_outputs/**/outputs/
!tests/evaluation_cases/llm_outputs/**/outputs/**
!tests/evaluation_cases/llm_outputs_bad/**/outputs/
!tests/evaluation_cases/llm_outputs_bad/**/outputs/**

# Large or regenerated review/scan outputs kept out of the baseline.
test output/
test output/phase3_regression/
test output/phase4_review/
test output/phase4_5_hardening/
test output/proposed_changes/
test output/**/*.json
!test output/phase7_release_hardening/evaluation_matrix.json
!test output/phase9_real_llm_review_evaluation/llm_quality_matrix.json
test output/**/*.html
test output/**/*.zip

